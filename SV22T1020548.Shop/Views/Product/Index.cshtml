@model SV22T1020548.Models.Common.PagedResult<SV22T1020548.Models.Catalog.Product>
@using SV22T1020548.Models.Catalog
@{
    ViewData["Title"] = "Sản phẩm";
    var categories = ViewBag.Categories as List<SV22T1020548.Models.Catalog.Category>
                     ?? new List<SV22T1020548.Models.Catalog.Category>();
    string searchValue = ViewBag.SearchValue ?? "";
    int categoryID = (int)(ViewBag.CategoryID ?? 0);
    decimal minPrice = (decimal)(ViewBag.MinPrice ?? 0m);
    decimal maxPrice = (decimal)(ViewBag.MaxPrice ?? 0m);
}

<h4 class="fw-bold mb-4"><i class="bi bi-grid me-2 text-primary"></i>Danh sách sản phẩm</h4>

<!-- BỘ LỌC TÌM KIẾM -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form id="productSearchForm" method="get" asp-controller="Product" asp-action="Index">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Tên sản phẩm</label>
                    <input name="searchValue" value="@searchValue" class="form-control"
                           placeholder="Nhập tên sản phẩm..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Loại hàng</label>
                    <select name="categoryID" class="form-select">
                        <option value="0">-- Tất cả loại hàng --</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.CategoryID" selected="@(cat.CategoryID == categoryID)">
                                @cat.CategoryName
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Giá từ (đ)</label>
                    <input name="minPrice" value="@(minPrice > 0 ? minPrice.ToString() : "")"
                           type="number" min="0" step="10000" class="form-control" placeholder="0" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Đến (đ)</label>
                    <input name="maxPrice" value="@(maxPrice > 0 ? maxPrice.ToString() : "")"
                           type="number" min="0" step="10000" class="form-control" placeholder="Không giới hạn" />
                </div>
                <div class="col-md-1 d-grid">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="searchResult">
    @await Html.PartialAsync("_ProductGrid", Model)
</div>

@section Scripts {
<script>
function addToCart(productID, btn) {
    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

    fetch('/Cart/Add?id=' + productID)
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                // Cập nhật badge
                const badges = document.querySelectorAll('.cart-badge');
                badges.forEach(b => b.textContent = data.count > 99 ? '99+' : data.count);
                if (badges.length === 0 && data.count > 0) {
                    const cartLink = document.querySelector('a[href*="/Cart"]');
                    if (cartLink) {
                        const badge = document.createElement('span');
                        badge.className = 'position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger cart-badge';
                        badge.style.fontSize = '.65rem';
                        badge.textContent = data.count;
                        cartLink.style.position = 'relative';
                        cartLink.appendChild(badge);
                    }
                }
                btn.innerHTML = '<i class="bi bi-check me-1"></i>Đã thêm!';
                btn.className = btn.className.replace('btn-success', 'btn-secondary');
                setTimeout(() => {
                    btn.innerHTML = orig;
                    btn.className = btn.className.replace('btn-secondary', 'btn-success');
                    btn.disabled = false;
                }, 1500);
            } else {
                alert(data.message || 'Không thể thêm vào giỏ hàng!');
                btn.innerHTML = orig;
                btn.disabled = false;
            }
        })
        .catch(() => {
            alert('Lỗi kết nối!');
            btn.innerHTML = orig;
            btn.disabled = false;
        });
}
</script>

<script>
    // AJAX search & pagination cho Shop (tránh reload toàn trang)
    document.addEventListener("DOMContentLoaded", function () {
        const form = document.getElementById("productSearchForm");
        const container = document.getElementById("searchResult");
        if (!form || !container) return;

        function buildQuery(page) {
            const formData = new FormData(form);
            const params = new URLSearchParams();

            for (const [key, value] of formData.entries()) {
                const strVal = String(value ?? "").trim();
                if (strVal !== "") params.append(key, strVal);
            }

            params.set("page", String(page));
            return params.toString();
        }

        async function load(page) {
            const url = form.action + "?" + buildQuery(page);
            container.innerHTML = `<div class="text-center py-4 text-muted">
                <div class="spinner-border spinner-border-sm me-2"></div>Đang tải...</div>`;

            try {
                const res = await fetch(url, {
                    method: "GET",
                    headers: { "X-Requested-With": "XMLHttpRequest" }
                });
                const html = await res.text();
                container.innerHTML = html;
            } catch (e) {
                container.innerHTML = `<div class="alert alert-danger m-0">
                    Không thể tải dữ liệu. Vui lòng thử lại.</div>`;
            }
        }

        form.addEventListener("submit", function (e) {
            e.preventDefault();
            load(1);
        });

        // Event delegation: xử lý pagination trong partial
        container.addEventListener("click", function (e) {
            const link = e.target.closest("a.shop-page-link");
            if (!link) return;

            e.preventDefault();
            const page = parseInt(link.dataset.page || "1", 10);
            if (!Number.isFinite(page)) return;
            load(page);
        });
    });
</script>
}
