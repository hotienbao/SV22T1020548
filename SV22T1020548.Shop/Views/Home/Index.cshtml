@{
    ViewData["Title"] = "Trang chủ";
}

<!-- HERO -->
<div class="p-5 mb-4 bg-dark text-white rounded-3 text-center" style="background: linear-gradient(135deg,#1a1a2e,#16213e,#0f3460) !important;">
    <h1 class="display-5 fw-bold text-warning mb-3">
        <i class="bi bi-shop me-2"></i>Chào mừng đến HTB Shop
    </h1>
    <p class="lead mb-4 text-light">Hệ thống mua sắm trực tuyến – Giá tốt, Giao hàng nhanh, Uy tín hàng đầu.</p>
    <a asp-controller="Product" asp-action="Index" class="btn btn-warning btn-lg px-5 fw-bold shadow">
        <i class="bi bi-grid me-2"></i>Khám phá sản phẩm
    </a>
</div>

<!-- FEATURES -->
<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center p-4 h-100">
            <i class="bi bi-truck text-primary" style="font-size:2.5rem"></i>
            <h5 class="mt-3 fw-bold">Giao hàng toàn quốc</h5>
            <p class="text-muted mb-0">Miễn phí vận chuyển đơn hàng từ 500.000đ</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center p-4 h-100">
            <i class="bi bi-shield-check text-success" style="font-size:2.5rem"></i>
            <h5 class="mt-3 fw-bold">Bảo đảm chính hãng</h5>
            <p class="text-muted mb-0">100% sản phẩm có nguồn gốc rõ ràng, chính hãng</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center p-4 h-100">
            <i class="bi bi-arrow-repeat text-warning" style="font-size:2.5rem"></i>
            <h5 class="mt-3 fw-bold">Đổi trả dễ dàng</h5>
            <p class="text-muted mb-0">Hỗ trợ đổi trả trong vòng 7 ngày kể từ khi nhận hàng</p>
        </div>
    </div>
</div>

<!-- CTA -->
<div class="text-center mt-4">
    <h4 class="fw-bold mb-3">Bắt đầu mua sắm ngay hôm nay!</h4>
    <a asp-controller="Account" asp-action="Register" class="btn btn-outline-dark me-3 px-4">
        <i class="bi bi-person-plus me-1"></i>Đăng ký tài khoản
    </a>
    <a asp-controller="Product" asp-action="Index" class="btn btn-dark px-4">
        <i class="bi bi-bag me-1"></i>Xem sản phẩm
    </a>
</div>
