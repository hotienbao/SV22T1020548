@model SV22T1020548.Models.Common.PagedResult<SV22T1020548.Models.Catalog.Product>
@{
    ViewBag.Title = "Quản lý Mặt hàng";
}

@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary d-flex align-items-center ms-1">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Product" method="get">
            <div class="row g-2">
                <div class="col-sm-3">
                    <select class="form-select" name="categoryID">
                        <option value="0">-- Tất cả loại hàng --</option>
                        @foreach (var c in ViewBag.Categories)
                        {
                            if (c.CategoryID == ViewBag.CategoryID)
                            {
                                <option value="@c.CategoryID" selected>@c.CategoryName</option>
                            }
                            else
                            {
                                <option value="@c.CategoryID">@c.CategoryName</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-sm-3">
                    <select class="form-select" name="supplierID">
                        <option value="0">-- Tất cả nhà cung cấp --</option>
                        @foreach (var s in ViewBag.Suppliers)
                        {
                            if (s.SupplierID == ViewBag.SupplierID)
                            {
                                <option value="@s.SupplierID" selected>@s.SupplierName</option>
                            }
                            else
                            {
                                <option value="@s.SupplierID">@s.SupplierName</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-sm-6">
                    <div class="input-group">
                        <input type="text"
                               name="searchValue"
                               value="@ViewBag.SearchValue"
                               class="form-control"
                               placeholder="Nhập tên mặt hàng cần tìm..." autofocus />
                        <button type="submit" class="btn btn-info d-flex align-items-center">
                            <i class="bi bi-search me-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> mặt hàng
</div>

<div class="card">
    <div class="card-body p-1 table-responsive">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th class="text-center" style="width:80px;">Ảnh</th>
                    <th>Tên mặt hàng</th>
                    <th>Đơn vị tính</th>
                    <th>Giá</th>
                    <th class="text-center" style="width:120px;">Trạng thái</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">Không tìm thấy mặt hàng nào phù hợp!</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td class="text-center align-middle">
                                <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                     alt="Ảnh" class="border rounded" style="width: 50px; height: 50px; object-fit: cover;" />
                            </td>
                            <td class="align-middle fw-bold">@item.ProductName</td>
                            <td class="align-middle">@item.Unit</td>
                            <td class="align-middle text-danger fw-bold">@item.Price.ToString("N0")</td>
                            <td class="text-center align-middle">
                                @if (item.IsSelling == true)
                                {
                                    <span class="badge bg-success">Đang bán</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Ngừng bán</span>
                                }
                            </td>
                            <td class="text-center text-nowrap align-middle">
                                <a href="~/Product/Edit/@item.ProductID" class="btn btn-sm btn-primary" title="Cập nhật">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Product/Delete/@item.ProductID" class="btn btn-sm btn-danger ms-1" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer text-center">
        @{
            var controllerName = ViewContext.RouteData.Values["controller"];
        }
        <ul class="pagination justify-content-center m-0">
            @if (Model.Page > 1)
            {
                <li class="page-item"><a class="page-link" href="~/@controllerName?searchValue=@ViewBag.SearchValue&categoryID=@ViewBag.CategoryID&supplierID=@ViewBag.SupplierID&page=@(Model.Page - 1)">&laquo;</a></li>
            }

            @{
                int windowSize = 5;
                int startPage = Math.Max(1, Model.Page - windowSize / 2);
                int endPage = Math.Min(Model.PageCount, startPage + windowSize - 1);
                if (endPage - startPage + 1 < windowSize) { startPage = Math.Max(1, endPage - windowSize + 1); }
            }

            @if (startPage > 1)
            {
                <li class="page-item"><a class="page-link" href="~/@controllerName?searchValue=@ViewBag.SearchValue&categoryID=@ViewBag.CategoryID&supplierID=@ViewBag.SupplierID&page=1">1</a></li>
                if (startPage > 2)
                {
                    <li class="page-item disabled"><span class="page-link text-muted">...</span></li>
                }
            }

            @for (int p = startPage; p <= endPage; p++)
            {
                if (p == Model.Page)
                {
                    <li class="page-item active"><span class="page-link">@p</span></li>
                }
                else
                {
                    <li class="page-item"><a class="page-link" href="~/@controllerName?searchValue=@ViewBag.SearchValue&categoryID=@ViewBag.CategoryID&supplierID=@ViewBag.SupplierID&page=@p">@p</a></li>
                }
            }

            @if (endPage < Model.PageCount)
            {
                if (endPage < Model.PageCount - 1)
                {
                    <li class="page-item disabled"><span class="page-link text-muted">...</span></li>
                }
                <li class="page-item"><a class="page-link" href="~/@controllerName?searchValue=@ViewBag.SearchValue&categoryID=@ViewBag.CategoryID&supplierID=@ViewBag.SupplierID&page=@Model.PageCount">@Model.PageCount</a></li>
            }

            @if (Model.Page < Model.PageCount)
            {
                <li class="page-item"><a class="page-link" href="~/@controllerName?searchValue=@ViewBag.SearchValue&categoryID=@ViewBag.CategoryID&supplierID=@ViewBag.SupplierID&page=@(Model.Page + 1)">&raquo;</a></li>
            }
        </ul>
    </div>
</div>