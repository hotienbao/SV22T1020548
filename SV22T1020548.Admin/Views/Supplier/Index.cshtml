@model SV22T1020548.Models.Common.PagedResult<SV22T1020548.Models.Partner.Supplier>
@{
    ViewBag.Title = "Quản lý Nhà cung cấp";
}

@section PageToolBar {
    <a href="~/Supplier/Create" class="btn btn-primary d-flex align-items-center ms-1">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Supplier" method="get">
            <div class="input-group">
                <input type="text"
                       name="searchValue"
                       value="@ViewBag.SearchValue"
                       class="form-control"
                       placeholder="Nhập tên nhà cung cấp hoặc tên giao dịch..." autofocus />
                <button type="submit" class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> nhà cung cấp
</div>

<div class="card">
    <div class="card-body p-1 table-responsive">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Tên nhà cung cấp</th>
                    <th>Tên giao dịch</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th>Tỉnh/Thành</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">Không tìm thấy nhà cung cấp nào phù hợp!</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td class="align-middle">@item.SupplierName</td>
                            <td class="align-middle">@item.ContactName</td>
                            <td class="align-middle">@item.Phone</td>
                            <td class="align-middle">@item.Email</td>
                            <td class="align-middle">@item.Address</td>
                            <td class="align-middle">@item.Province</td>
                            <td class="text-center text-nowrap align-middle">
                                <a href="~/Supplier/Edit/@item.SupplierID" class="btn btn-sm btn-primary" title="Cập nhật">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Supplier/Delete/@item.SupplierID" class="btn btn-sm btn-danger ms-1" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer text-center">
        @{
            var controllerName = ViewContext.RouteData.Values["controller"];
        }
        <ul class="pagination justify-content-center m-0">

            @if (Model.Page > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="~/@controllerName?searchValue=@ViewBag.SearchValue&page=@(Model.Page - 1)">&laquo;</a>
                </li>
            }

            @{
                int windowSize = 5;
                int startPage = Math.Max(1, Model.Page - windowSize / 2);
                int endPage = Math.Min(Model.PageCount, startPage + windowSize - 1);

                if (endPage - startPage + 1 < windowSize)
                {
                    startPage = Math.Max(1, endPage - windowSize + 1);
                }
            }

            @if (startPage > 1)
            {
                <li class="page-item"><a class="page-link" href="~/@controllerName?searchValue=@ViewBag.SearchValue&page=1">1</a></li>
                if (startPage > 2)
                {
                    <li class="page-item disabled"><span class="page-link text-muted">...</span></li>
                }
            }

            @for (int p = startPage; p <= endPage; p++)
            {
                if (p == Model.Page)
                {
                    <li class="page-item active"><span class="page-link">@p</span></li>
                }
                else
                {
                    <li class="page-item"><a class="page-link" href="~/@controllerName?searchValue=@ViewBag.SearchValue&page=@p">@p</a></li>
                }
            }

            @if (endPage < Model.PageCount)
            {
                if (endPage < Model.PageCount - 1)
                {
                    <li class="page-item disabled"><span class="page-link text-muted">...</span></li>
                }
                <li class="page-item"><a class="page-link" href="~/@controllerName?searchValue=@ViewBag.SearchValue&page=@Model.PageCount">@Model.PageCount</a></li>
            }

            @if (Model.Page < Model.PageCount)
            {
                <li class="page-item">
                    <a class="page-link" href="~/@controllerName?searchValue=@ViewBag.SearchValue&page=@(Model.Page + 1)">&raquo;</a>
                </li>
            }
        </ul>
    </div>
</div>